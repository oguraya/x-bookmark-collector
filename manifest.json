{
  "manifest_version": 3,
  "name": "X Bookmark URL Collector",
  "version": "1.0.0",
  "description": "X（Twitter）のブックマークからツイートURLを収集します",
  "permissions": ["activeTab", "storage"],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/i/bookmarks*", "https://twitter.com/i/bookmarks*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
